{
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "是休息时间吗~？嘿嘿・我想吃美食~",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "那是自然！在这无聊的等待里，随便挑一块被遗忘的宝石去吧！",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "你还在等啊？我不急——那堆东西你慢挑。你等得起，我也等得起！",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "我这里有无数宝石，但好像没见着你在等的那件啊……",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "回应",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "辛苦了~那要不要一起去吃点好吃的呢~？",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "DARV.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "……罢了。把选择留到下次吧。看来你习惯把“下次”等得很久。",

  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "咦？失败了吗？我好像保留太多实力了，嘿嘿。",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "[sine]...去... 塔里... ..继续... 等待.....[/sine]",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "[sine]...我听见了... ..你的脚步..... \n...等待... ..从不赶路.....[/sine]",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "[sine]...你.. 还缺... ..什么...？[/sine]",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "确认",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "是！纠察队委员小春！准备好了~！",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "NEOW.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "[sine]...去吧... \n..我会... 在你...回头的地方... ..还在.....[/sine]",

  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "跟怪物战斗的理由？嗯……我想守护大家~",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "哎呀，就算是旧外套，接受了我的赐福也能变得光彩照人呢。",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "你是在等迟到的胜利么？快过来，让我把你打扮得更像一个赢家。",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "哪怕你要将自己系在某个永远不会到来的时刻上，也不该如此灰头土脸呀。",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "婉拒",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "要依照规定好好穿制服喔，知道吗？",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "NONUPEIPE.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "真是不懂情趣。拿去吧。让我看着你继续等——穿着我的光，也穿着你的耐心。",

  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "只要这样挥舞，被打到的人超级痛的~",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "都不疯！！都不疯！！试试这个打发时间！！",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "别急别急！你不要急！等待是……是……很长的闪电！！",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "送你东西！！想要什么？“明天还会响”的声音！？",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "回应",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "什么……？你好奇有几公斤？……嘿嘿，这个嘛……",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "OROBAS.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "好！好！那我们说定了：我继续吵！！",

  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "这样就能保护更多人了吗~？",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "[thinky_dots]安静的旅人……拿走我的一部分，在潮水里寻找安宁吧……[/thinky_dots]",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "[thinky_dots]醒着的人总想赶路，睡着的人才懂停留……你也睡一会儿吧……[/thinky_dots]",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "[thinky_dots]拿走我的血肉吧……一点“不会催促你”的血肉……[/thinky_dots]",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "回答",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "嘿嘿，我感觉到自己变强了！",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "PAEL.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "[thinky_dots]收下吧……让你继续躺在这里……等那条还没来的路……[/thinky_dots]",

  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "让我看看~？",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "[b]拿着这把武器！去变强！！！[/b]",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "[b]你的血早就凉了！但战斗能让耐心也沸腾起来！！[/b]",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "[b]不要再等那个人了！与我一战，这就是你现在的命运！！[/b]",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "退让",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "充电完毕！那出发去击败怪物吧~？",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "TANX.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "[b]懦弱！！但你有无尽的耐心！！收下这把武器去等待吧！[/b]",

  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "这是「库库」这个角色的限量版周边，是我和蕾伊一起买的~很可爱吧？",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "没到点也没关系呀。快进来吧，让我在等待中把你[jitter][b]温暖[/b][/jitter]一下。",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "你背着的唯一行李就是那点[jitter][b]犹豫[/b][/jitter]么？要不要让我帮你烧掉呀？",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "亲爱的，尝尝我给你做的[jitter][b]点心[/b][/jitter]吧。是那种要慢慢凉、慢慢等的点心哦。",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "推辞",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "嗯……？你怎么了？哈哈，不好意思说可爱吗~？",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "TEZCATARA.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "好吧，那就尝一口吧。然后我们继续等——等苦味[jitter][b]散尽[/b][/jitter]。",

  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.char": "啊・这个陷阱？是特别订做的喔~",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0.next": "继续",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1.ancient": "不值钱的[sine]时间[/sine]积攒起来，也是很可观的呢……",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "我通常把“立刻”卖得很贵。可面对你，我连[sine]“以后”[/sine]都想标上高价。",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.ancient": "如果在契约的底端写上一行小字：允许你[sine]永远等下去[/sine]——你就签么？",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0.next": "回应",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.char": "救助身陷危险的人、消灭怪物确实很有意义…",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1.next": "继续",
  "VAKUU.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2.ancient": "拿去你的代价。我绝不会叫醒你——除非[sine]那一刻[/sine]真的来临。",

  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0r.ancient": "卡厄思？那是什么",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-0r.next": "回答",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1r.char": "啊，卡厄思啊！那是……是……我也说不清楚了！",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-1r.next": "继续",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.0-2r.ancient": "羊宫妃那牛逼",

  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.ancient": "卡厄思？那是什么",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-0r.next": "继续",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-1r.char": "啊，卡厄思啊！那是……是……我也说不清楚了！",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-1r.next": "继续",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.1-2r.ancient": "羊宫妃那牛逼",

  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0r.ancient": "卡厄思？那是什么",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-0r.next": "继续",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1r.char": "啊，卡厄思啊！那是……是……我也说不清楚了！",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-1r.next": "继续",
  "THE_ARCHITECT.talk.CHAOS_HARU_CHARACTER_CHAOS_HARU_CHARACTER.2-2r.ancient": "羊宫妃那牛逼"
